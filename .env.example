# Port
PORT=8000

# Auth dir
CHATGPT_LOCAL_HOME=/data
# Optional multi-account mode: comma-separated auth.json files
# CHATGPT_LOCAL_AUTH_FILES=/data/acc1/auth.json,/data/acc2/auth.json
# Routing strategy: round-robin|random|first
CHATGPT_LOCAL_ROUTING_STRATEGY=round-robin
# Retry rounds after first attempt (0-10)
CHATGPT_LOCAL_REQUEST_RETRY=3
# Max backoff interval seconds between retry rounds
CHATGPT_LOCAL_MAX_RETRY_INTERVAL=30
# Optional dashboard settings
# CHATMOCK_DASHBOARD_LOG_PATH=/var/log/chatmock/chatmock.log
# CHATMOCK_SERVICE_NAME=chatmock

# show request/stream logs
VERBOSE=false

# OAuth client id (modify only if you know what you're doing)
# CHATGPT_LOCAL_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann

# Reasoning controls
CHATGPT_LOCAL_REASONING_EFFORT=medium       # minimal|low|medium|high
CHATGPT_LOCAL_REASONING_SUMMARY=auto        # auto|concise|detailed|none
CHATGPT_LOCAL_REASONING_COMPAT=think-tags   # legacy|o3|think-tags|current
CHATGPT_LOCAL_EXPOSE_REASONING_MODELS=false

# Enable default web search tool
CHATGPT_LOCAL_ENABLE_WEB_SEARCH=false

# Force a specific model name
# CHATGPT_LOCAL_DEBUG_MODEL=gpt-5
